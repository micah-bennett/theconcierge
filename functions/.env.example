# Set secrets via Firebase CLI (do not commit real passwords):
#
#   firebase functions:secrets:set SMTP_PASS
#
# Optional string params (defaults work for GoDaddy + micah@hvconcierge.com):
#
#   firebase functions:config:set ...  # legacy — use params instead:
#
#   firebase functions:secrets:set SMTP_PASS
#   firebase deploy --only functions
#
# For GoDaddy email on hvconcierge.com, typical values:
#   SMTP_USER=micah@hvconcierge.com
#   SMTP_HOST=smtpout.secureserver.net
#   SMTP_PORT=465
#   NOTIFY_EMAIL=micah@hvconcierge.com
#
# Google Workspace instead:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=micah@hvconcierge.com
#   (use an App Password for SMTP_PASS)
